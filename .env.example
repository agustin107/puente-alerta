# ============================================
# PUENTE ALERTA - Configuration
# ============================================

# Telegram Bot Token (obtener de @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Group Chat ID (donde se enviarán las alertas)
# Para obtenerlo: agregar el bot al grupo, enviar un mensaje,
# y visitar https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# YouTube Live Stream URL
YOUTUBE_URL=https://www.youtube.com/watch?v=WxqFswgQqUk

# ============================================
# DETECTION SETTINGS
# ============================================

# Intervalo entre capturas de frames (en segundos)
FRAME_INTERVAL=3

# Confianza mínima para detección de personas (0.0 - 1.0)
DETECTION_CONFIDENCE=0.4

# Tiempo mínimo (en segundos) que una persona debe estar
# inmóvil en zona de riesgo antes de alertar
ALERT_THRESHOLD_SECONDS=180

# Cooldown entre alertas para evitar spam (en segundos)
ALERT_COOLDOWN_SECONDS=300

# ============================================
# YOLO MODEL
# ============================================

# Modelo YOLO a usar (yolov8n.pt es el más liviano)
# Opciones: yolov8n.pt, yolov8s.pt, yolov8m.pt
YOLO_MODEL=yolov8n.pt

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
